'''Print index of a given element in an array. If not present,
print -1'''


def SearchNum(arr, target, n):
    if n < 0:
        return -1
    if arr[n] == target:
        return n
    res = SearchNum(arr, target, n-1)
    return res
    
    

    
arr = [5,6,8,7,9,5,2]
target = 10
ans = SearchNum(arr,target, len(arr)-1)
print(ans)
