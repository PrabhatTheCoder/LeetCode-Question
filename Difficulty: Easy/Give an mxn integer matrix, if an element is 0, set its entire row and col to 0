#  Give an mxn integer matrix, if an element is 0, set its entire row and col to 0

def set_zeroes(matrix):
    if not matrix:
        return
    
    m, n = len(matrix), len(matrix[0])
    
    rows_to_zero = set()
    cols_to_zero = set()
    
    # Step 1: Find all rows and columns that need to be zeroed
    for i in range(m):
        for j in range(n):
            if matrix[i][j] == 0:
                rows_to_zero.add(i)
                cols_to_zero.add(j)
    
    # Step 2: Set the rows to zero
    for i in range(m):
        for j in range(n):
            if i in rows_to_zero or j in cols_to_zero:
                matrix[i][j] = 0
    
    return matrix
