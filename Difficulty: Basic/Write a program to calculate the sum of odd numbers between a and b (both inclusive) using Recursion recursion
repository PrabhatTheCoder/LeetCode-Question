'''Write a program to calculate the sum of odd numbers between a and b (both inclusive) using recursion'''

def oddNumbers(a: int, b: int) -> int:
    if a > b:  # Base case: no numbers left to add
        return 0
    if a % 2 != 0:  # If 'a' is odd, include it in the sum
        return a + oddNumbers(a + 1, b)
    else:  # If 'a' is even, skip it and move to the next number
        return oddNumbers(a + 1, b)

# Test the function
val = oddNumbers(1, 6)
print(val)  # Output: 9 (1 + 3 + 5)
