'''Given a number ‘n’. Predict whether ‘n’ is a valid perfect square or not.
 Input 1: n = 36
 Output 1: yes
 Input 2: n = 45
 Output 2: no '''
 
 
class Solution():
    
    def findPerfectSquare(self,nums):
        low = 0
        high = nums
        
        while low<=high:
            mid = low + (high-low)//2
            
            Val = mid*mid
            if Val != nums:
                if Val < nums:
                    low = mid + 1
                else:
                    high = mid - 1
            if Val == nums:
                return "Yes"
                
        return "No"

nums = 36
# nums = 45

s = Solution()
ans = s.findPerfectSquare(nums)
print(ans)
